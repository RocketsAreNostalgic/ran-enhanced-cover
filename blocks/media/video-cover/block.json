{
	"$schema": "https://schemas.wp.org/wp/6.5/block.json",
	"version": "1.2.0",
	"apiVersion": 3,
	"name": "ran/enhanced-cover",
	"title": "Ran Enhanced Cover",
	"category": "media",
	"description": "Cover-style background video with a poster fallback, colour wash, reduced-motion handling, and a pause/play control.",
	"textdomain": "ran-enhanced-cover",
	"attributes": {
		"videoId": {
			"type": "number",
			"default": 0
		},
		"videoUrl": {
			"type": "string",
			"default": ""
		},
		"videoSources": {
			"type": "array",
			"default": []
		},
		"posterId": {
			"type": "number",
			"default": 0
		},
		"posterUrl": {
			"type": "string",
			"default": ""
		},
		"focalPoint": {
			"type": "object",
			"default": {
				"x": 0.5,
				"y": 0.5
			}
		},
		"minHeight": {
			"type": "number",
			"default": 80
		},
		"minHeightUnit": {
			"type": "string",
			"default": "vh"
		},
		"contentPosition": {
			"type": "string",
			"default": "center left"
		},
		"backgroundColor": {
			"type": "string",
			"default": ""
		},
		"customBackgroundColor": {
			"type": "string",
			"default": ""
		},
		"overlayColor": {
			"type": "string",
			"default": ""
		},
		"customOverlayColor": {
			"type": "string",
			"default": ""
		},
		"overlayOpacity": {
			"type": "number",
			"default": 70
		},
		"pauseControl": {
			"type": "boolean",
			"default": true
		},
		"pauseControlPosition": {
			"type": "string",
			"default": "bottom right"
		},
		"pauseControlInsetBlock": {
			"type": "string",
			"default": "1rem"
		},
		"pauseControlInsetInline": {
			"type": "string",
			"default": "1rem"
		}
	},
	"supports": {
		"align": true,
		"anchor": true,
		"html": false,
		"shadow": true,
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true,
			"__experimentalDefaultControls": {
				"padding": true,
				"blockGap": true
			}
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true,
			"__experimentalDefaultControls": {
				"color": true,
				"radius": true,
				"style": true,
				"width": true
			}
		},
		"color": {
			"heading": true,
			"text": true,
			"background": false,
			"__experimentalSkipSerialization": [
				"gradients"
			],
			"enableContrastChecker": false
		},
		"dimensions": {
			"aspectRatio": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalFontWeight": true,
			"__experimentalFontStyle": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalLetterSpacing": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"layout": {
			"allowJustification": false
		},
		"filter": {
			"duotone": true
		},
		"allowedBlocks": true
	},
	"selectors": {
		"filter": {
			"duotone": ".wp-block-ran-enhanced-cover > .ran-video-cover__media"
		}
	},
	"example": {
		"attributes": {
			"minHeight": 60,
			"minHeightUnit": "vh",
			"contentPosition": "center left",
			"backgroundColor": "",
			"customBackgroundColor": "",
			"overlayColor": "background",
			"customOverlayColor": "",
			"overlayOpacity": 70,
			"pauseControl": true,
			"pauseControlPosition": "bottom right"
		},
		"innerBlocks": [
			{
				"name": "core/heading",
				"attributes": {
					"level": 1,
					"content": "Video cover"
				}
			},
			{
				"name": "core/paragraph",
				"attributes": {
					"content": "Add heading or hook text over background media."
				}
			}
		]
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
